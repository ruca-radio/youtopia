{
  "name": "youtopia",
  "productName": "Youtopia",
  "version": "2.0.11",
  "description": "Youtopia",
  "main": ".vite/main/index.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish:dry": "electron-forge publish --dry-run",
    "publish:fromdry": "electron-forge publish --from-dry-run",
    "publish": "electron-forge publish",
    "verify:player-shell": "node scripts/verify-player-shell.mjs",
    "verify:firetv-receiver": "node scripts/verify-firetv-receiver.mjs",
    "probe:firetv-hls-volume": "node scripts/probe-firetv-hls-volume.mjs",
    "build:firetv-receiver": "bash scripts/build-firetv-receiver.sh",
    "lint": "eslint --ext .ts,.tsx,.vue .",
    "lint:fix": "eslint --ext .ts,.tsx,.vue . --fix",
    "typecheck": "tsc -p src/main/tsconfig.json --noEmit && tsc -p src/renderer/tsconfig.json --noEmit",
    "prettier": "prettier --check \"**/*.{ts,tsx,vue}\"",
    "prettier:fix": "prettier --write \"**/*.{ts,tsx,vue}\"",
    "postinstall": "husky install"
  },
  "keywords": [],
  "author": {
    "name": "NovusTheory",
    "email": "novustheory@gmail.com"
  },
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@electron-forge/cli": "~7.11.2",
    "@electron-forge/maker-deb": "~7.11.2",
    "@electron-forge/maker-rpm": "~7.11.2",
    "@electron-forge/maker-squirrel": "~7.11.2",
    "@electron-forge/maker-zip": "~7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "~7.11.2",
    "@electron-forge/plugin-fuses": "~7.11.2",
    "@electron-forge/plugin-vite": "~7.11.2",
    "@electron-forge/publisher-github": "~7.11.2",
    "@electron/fuses": "^2.1.2",
    "@eslint/js": "^10.0.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.4.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vue-eslint-parser": "^10.4.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/error": "^4.2.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.49",
    "conf": "^15.1.0",
    "electron-log": "5.4.4",
    "electron-squirrel-startup": "^1.0.1",
    "fastify": "^5.8.5",
    "fastify-socket.io": "^5.1.0",
    "material-symbols": "^0.45.2",
    "socket.io": "^4.8.3",
    "vue": "^3.5.38"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "prettier --write",
      "eslint --cache --fix"
    ]
  },
  "packageManager": "yarn@4.5.1"
}
