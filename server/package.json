{
  "name": "youtopia-server",
  "version": "0.1.0",
  "description": "YouTopia Intelligent Music Server — standalone Node/TS service",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@sinclair/typebox": "^0.34.14",
    "conf": "^13.0.0",
    "fastify": "^5.3.2",
    "fuse.js": "^7.4.2",
    "music-metadata": "^11.13.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.28.0",
    "tsx": "^4.19.4",
    "typescript": "~5.9.0-dev.20250527",
    "typescript-eslint": "^8.32.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
